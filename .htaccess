# Izinkan akses ke file JSON
<Files "students.json">
    Order Allow,Deny
    Allow from all
</Files>

# Redirect jika perlu
RewriteEngine On
# Jika ada permintaan ke /api/students tanpa ekstensi, arahkan ke file yang tersedia
RewriteRule ^api/students$ api/student.php [L]
RewriteRule ^api/stats$ api/api/state.php [L]
